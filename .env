# ─────────────────────────────────────────────────────────────
# Discord OAuth2 Credentials
# How to get these:
#   1. Go to https://discord.com/developers/applications
#   2. Click "New Application" (or select your existing one)
#   3. Go to "OAuth2" in the left sidebar
#   4. Copy the CLIENT ID and CLIENT SECRET from that page
#   5. Under "Redirects", add: http://localhost:3000/auth/discord/callback
# ─────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=1489408082332352573
DISCORD_CLIENT_SECRET=9sPGWs800eblDitPdkxcBr3b8DOzDe5J

# The URL Discord redirects back to after login
# Change this to your production domain when deploying
DISCORD_CALLBACK_URL=http://192.168.1.112:3000/auth/discord/callback

# Your Discord server (guild) ID — already filled in
DISCORD_GUILD_ID=1464078037560856689

# Members role — can view trades
DISCORD_REQUIRED_ROLE_ID=1464462462060597361

# Mods role — can add/edit/delete trades
DISCORD_MOD_ROLE_ID=1489438204183711914 #1464079296061505569

# Random secret used to sign sessions — change this to any long random string
SESSION_SECRET=change-this-to-a-long-random-string

# PostgreSQL connection string
# Local: postgres://user:password@localhost:5432/stockideas
# Railway: copy from Railway dashboard → your Postgres service → Connect
DATABASE_URL=

# Discord Bot Token — from Developer Portal → your app → Bot tab
DISCORD_BOT_TOKEN=
# Channel to post trade notifications into
DISCORD_NOTIFY_CHANNEL=
